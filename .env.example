# LLM API — any OpenAI-compatible endpoint
LLM_BASE_URL=https://api.openai.com/v1          # or Nebius, Together, local SGLang, etc.
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-ai/DeepSeek-V3               # model identifier on your provider
LLM_FALLBACK_MODEL=                             # optional fallback if primary model not found

# Path to configs/local.yaml in the synthetic_sampling repo
# That file tells the loader where the survey data files live on disk
DATA_CONFIG_PATH=C:/path/to/synthetic_sampling/configs/local.yaml
